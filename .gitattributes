# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# GitHub linguist overrides
*.md linguist-documentation
docs/** linguist-documentation
ENCRYPTION.md linguist-documentation
CRIPTOGRAFIA.md linguist-documentation
GITHUB_ACTIONS.md linguist-documentation
migrate_to_encrypted.py linguist-language=Python
build-local.ps1 linguist-language=PowerShell
